# Database (see src/vessel_valuation/config.py)
# Unset: tests use in-memory SQLite; Alembic CLI uses ./vessel_valuation.db
#
# Local Dash (`make dev`) — default; file SQLite in the project root:
# DATABASE_URL=sqlite:///vessel_valuation.db
#
# Optional Docker Compose (`make docker-up`) — app service → db service:
# DATABASE_URL=postgresql+psycopg2://vessel:vessel@db:5432/vessel_valuation

# Dash app
# PORT=8050
# DASH_DEBUG=1
